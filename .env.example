# Unified Quant Platform environment configuration
# Copy this file to .env before first use. The Web Settings page reads and
# writes this same local .env file.
#
# Values under STOCK__SECTION__FIELD map directly to src.core.config.GlobalConfig.
# Strings are JSON strings, lists/objects are JSON, booleans are true/false.

# =============================================================================
# DATA SOURCES
# =============================================================================
STOCK__DATA__PROVIDER="akshare"
STOCK__DATA__CACHE_DIR="./cache"
STOCK__DATA__ADJ=null
STOCK__DATA__START_DATE="2024-01-01"
STOCK__DATA__END_DATE="2024-12-31"
STOCK__DATA__PROVIDERS={}
STOCK__DATA__LEVEL2={}

# Optional provider tokens. Keep real values only in .env.
TUSHARE_TOKEN=

# =============================================================================
# BACKTEST
# =============================================================================
STOCK__BACKTEST__INITIAL_CASH=100000.0
STOCK__BACKTEST__COMMISSION=0.001
STOCK__BACKTEST__SLIPPAGE=0.0
STOCK__BACKTEST__SLIPPAGE_TYPE="fixed"
STOCK__BACKTEST__MIN_TRADE_UNIT=100
STOCK__BACKTEST__ALLOW_SHORT=false

# =============================================================================
# RISK
# =============================================================================
STOCK__RISK__ENABLED=true
STOCK__RISK__STRICT_MODE=true
STOCK__RISK__MAX_LEVERAGE=1.0
STOCK__RISK__MAX_DRAWDOWN_PCT=0.2
STOCK__RISK__DAILY_LOSS_LIMIT_PCT=0.05
STOCK__RISK__MARGIN_CALL_LEVEL=0.5
STOCK__RISK__FORCE_LIQUIDATION_LEVEL=0.3
STOCK__RISK__MAX_POSITION_PCT=0.3
STOCK__RISK__MAX_POSITIONS=10
STOCK__RISK__MAX_SECTOR_EXPOSURE=0.5
STOCK__RISK__MIN_POSITION_VALUE=1000.0
STOCK__RISK__MAX_ORDER_VALUE=100000.0
STOCK__RISK__MAX_ORDER_PCT=0.1
STOCK__RISK__PRICE_DEVIATION_LIMIT=0.05
STOCK__RISK__MIN_ORDER_INTERVAL_SEC=1
STOCK__RISK__DEFAULT_STOP_LOSS_PCT=0.05
STOCK__RISK__DEFAULT_TAKE_PROFIT_PCT=0.15
STOCK__RISK__TRAILING_STOP_PCT=0.05
STOCK__RISK__ENABLE_AUTO_STOP=true

# =============================================================================
# EXECUTION
# =============================================================================
STOCK__EXECUTION__GATEWAY="paper"
STOCK__EXECUTION__MODE="vectorized"
STOCK__EXECUTION__ENABLE_MATCHING=true
STOCK__EXECUTION__ENABLE_SLIPPAGE=true
STOCK__EXECUTION__LIVE_GATEWAY={}

# =============================================================================
# LIVE TRADING
# =============================================================================
STOCK__LIVE_TRADING__ENABLED=false
STOCK__LIVE_TRADING__BROKER="xtp"
STOCK__LIVE_TRADING__ACCOUNT_ID=""
STOCK__LIVE_TRADING__GATEWAY_TYPE="xtp"
STOCK__LIVE_TRADING__GATEWAY_PROVIDER="self"
STOCK__LIVE_TRADING__QMT_PROVIDER="self"
STOCK__LIVE_TRADING__VNPY_GATEWAY=""
STOCK__LIVE_TRADING__VNPY_SETTING={}
STOCK__LIVE_TRADING__BROKER_OPTIONS={}
STOCK__LIVE_TRADING__SDK_PATH=""
STOCK__LIVE_TRADING__SDK_LOG_PATH=""
STOCK__LIVE_TRADING__AUTO_RECONNECT=true
STOCK__LIVE_TRADING__MAX_ORDERS_PER_SECOND=10.0

# =============================================================================
# REALTIME DATA
# =============================================================================
STOCK__REALTIME_DATA__PROVIDER="simulation"
STOCK__REALTIME_DATA__SYMBOLS=[]
STOCK__REALTIME_DATA__FALLBACK_PROVIDERS=[]
STOCK__REALTIME_DATA__INTERVAL_SECONDS=3.0
STOCK__REALTIME_DATA__REQUEST_TIMEOUT_SECONDS=5.0
STOCK__REALTIME_DATA__BAR_INTERVALS=[1,5]
STOCK__REALTIME_DATA__LEVEL2_PROVIDER="stub"

# =============================================================================
# PORTFOLIO
# =============================================================================
STOCK__PORTFOLIO__STRATEGIES=[]
STOCK__PORTFOLIO__REBALANCE_INTERVAL_DAYS=21
STOCK__PORTFOLIO__MAX_WEIGHT_PER_STRATEGY=0.4
STOCK__PORTFOLIO__MIN_WEIGHT_PER_STRATEGY=0.05
STOCK__PORTFOLIO__OPTIMIZATION_OBJECTIVE="sharpe"
STOCK__PORTFOLIO__CAPITAL_ALLOCATION={}

# =============================================================================
# STORAGE
# =============================================================================
STOCK__DATABASE__PATH="./cache/market_data.db"
STOCK__DATABASE__DUCKDB_PATH="./cache/market_data.duckdb"
STOCK__DATABASE__BACKUP_ENABLED=true
STOCK__DATABASE__BACKUP_INTERVAL_HOURS=24
STOCK__DATABASE__BACKUP_RETENTION_DAYS=30

# =============================================================================
# PLATFORM
# =============================================================================
STOCK__PLATFORM__JOB_STORE="./cache/platform/jobs.json"
STOCK__PLATFORM__JOB_STORE_FALLBACK=true
STOCK__PLATFORM__JOB_MAX_WORKERS=2

# =============================================================================
# MONITORING
# =============================================================================
STOCK__MONITORING__ENABLED=true
STOCK__MONITORING__HEALTH_CHECK_INTERVAL=60
STOCK__MONITORING__METRICS_PORT=9090
STOCK__MONITORING__ALERT_EMAIL=""
STOCK__MONITORING__OTLP_ENDPOINT=""
STOCK__MONITORING__ALERT_CHANNELS={}

# =============================================================================
# PERFORMANCE
# =============================================================================
STOCK__PERFORMANCE__MAX_WORKERS=4
STOCK__PERFORMANCE__CACHE_ENABLED=true
STOCK__PERFORMANCE__CACHE_EXPIRE_DAYS=1

# =============================================================================
# AI MODEL
# =============================================================================
# OpenAI-compatible stock-analysis summaries. Leave keys empty in git.
STOCK__AI__API_KEY=""
STOCK__AI__BASE_URL="https://api.openai.com/v1"
STOCK__AI__MODEL="gpt-4o-mini"
STOCK__AI__TIMEOUT_SECONDS=8.0

# Legacy process-env aliases still work and override .env at runtime.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# Common OpenAI-compatible provider examples. Uncomment one group in .env.
#
# DeepSeek
# STOCK__AI__BASE_URL="https://api.deepseek.com"
# STOCK__AI__MODEL="deepseek-chat"
#
# Moonshot / Kimi
# STOCK__AI__BASE_URL="https://api.moonshot.cn/v1"
# STOCK__AI__MODEL="moonshot-v1-8k"
#
# DashScope Qwen
# STOCK__AI__BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# STOCK__AI__MODEL="qwen-plus"
#
# Ollama local OpenAI-compatible endpoint
# STOCK__AI__BASE_URL="http://localhost:11434/v1"
# STOCK__AI__MODEL="qwen3:8b"

# =============================================================================
# LOGGING
# =============================================================================
STOCK__LOGGING__LEVEL="INFO"
STOCK__LOGGING__FILE=null
STOCK__LOGGING__FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
STOCK__LOGGING__JSON_FORMAT=false
STOCK__LOGGING__ROTATE_SIZE=10485760
STOCK__LOGGING__ROTATE_COUNT=5

# =============================================================================
# STRATEGY
# =============================================================================
STOCK__STRATEGY__NAME="default"
STOCK__STRATEGY__SYMBOLS=[]
STOCK__STRATEGY__PARAMS={}

# =============================================================================
# WEB / API OVERRIDES
# =============================================================================
# Optional runtime overrides for the local WebUI/API process.
# STOCK_ENV_PATH=.env
# PLATFORM_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# PLATFORM_FRONTEND_DIST=frontend/dist
# WEBUI_HOST=127.0.0.1
# WEBUI_PORT=8001
# VITE_API_BASE_URL=http://127.0.0.1:8001
